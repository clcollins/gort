# CI container image — all lint and validation tools pre-installed.
# Used by `make ci-all` locally and by GHA workflows remotely.
FROM registry.fedoraproject.org/fedora-minimal:42

ARG GOLANGCI_LINT_VERSION=v2.1.6
ARG YAMLLINT_VERSION=1.37.0
ARG MARKDOWNLINT_VERSION=0.20.0
ARG CHECKMAKE_VERSION=0.2.2
ARG PROMTOOL_VERSION=3.3.1

# System packages.
RUN microdnf install -y --nodocs \
      golang gcc glibc-devel \
      nodejs npm \
      python3-pip \
      ShellCheck \
      make git findutils tar gzip curl \
    && microdnf clean all

# Go tools — pinned versions, installed to /usr/local/bin.
ENV GOBIN=/usr/local/bin \
    GOPATH=/tmp/go \
    GOCACHE=/tmp/go-cache

RUN go install github.com/golangci/golangci-lint/v2/cmd/golangci-lint@${GOLANGCI_LINT_VERSION} \
    && golangci-lint version

RUN go install github.com/mrtazz/checkmake/cmd/checkmake@v${CHECKMAKE_VERSION} \
    && checkmake --version

# Python tools.
RUN pip3 install --no-cache-dir yamllint==${YAMLLINT_VERSION} \
    && yamllint --version

# Node tools.
RUN npm install -g markdownlint-cli2@${MARKDOWNLINT_VERSION} \
    && command -v markdownlint-cli2

# promtool — download pre-built binary.
RUN ARCH=$(case $(uname -m) in x86_64) echo amd64;; aarch64) echo arm64;; *) echo $(uname -m);; esac) \
    && curl -sSLf "https://github.com/prometheus/prometheus/releases/download/v${PROMTOOL_VERSION}/prometheus-${PROMTOOL_VERSION}.linux-${ARCH}.tar.gz" \
       | tar -xz --strip-components=1 -C /usr/local/bin "prometheus-${PROMTOOL_VERSION}.linux-${ARCH}/promtool" \
    && promtool --version

# Clean up Go module cache from tool installs.
RUN rm -rf /tmp/go /tmp/go-cache

WORKDIR /src
